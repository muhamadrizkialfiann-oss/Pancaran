rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidShipment(data) {
      return data.truckPlate is string && data.truckPlate.size() > 0 &&
             data.driverName is string && data.driverName.size() > 0 &&
             data.status in ['Pending', 'In Transit', 'Delivered', 'Cancelled'] &&
             data.origin is string &&
             data.destination is string;
    }

    match /shipments/{shipmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidShipment(request.resource.data);
      allow update: if isAuthenticated() && isValidShipment(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /custom_fields/{fieldId} {
      allow read, write: if isAuthenticated();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
